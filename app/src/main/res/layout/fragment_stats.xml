<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- 第一行：今日 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:id="@+id/textTodayMinutes" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_today_minutes" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:id="@+id/textTodayCount" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_today_count" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- 第二行：累计 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:id="@+id/textTotalMinutes" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_total_minutes" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Material3.CardView.Filled"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:layout_weight="1"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:id="@+id/textTotalCount" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_total_count" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- 待办数量 + 内容提供器查询 -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Material3.CardView.Filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:id="@+id/textPendingCount" style="@style/StatNumber"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" />
                    <TextView style="@style/StatLabel"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/stat_pending" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnProviderDemo"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/provider_demo"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_tasks"
                    app:iconSize="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 最近记录 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"
            android:text="@string/recent_sessions"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSessions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/textNoSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="24dp"
            android:text="@string/no_session"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
